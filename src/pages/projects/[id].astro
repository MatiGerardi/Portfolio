---
import Layout from "../../layouts/Layout.astro";
import Carousel from "../../components/Carousel.astro";
import { getCollection, render, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

type Props = { project: CollectionEntry<"projects"> };
const { project } = Astro.props;

// Use images array if available, otherwise fallback to single img
const carouselImages = project.data.images && project.data.images.length > 0 ? project.data.images : [project.data.img];

const { Content } = await render(project);
---

<Layout title={`${project.data.title} | Matias Gerardi Portfolio`} description={project.data.description}>
  <div class="gap-12 bg-mist-900">
    <main class="px-10 py-10 flex flex-col items-center bg-zinc-950">
      <div class="relative w-full max-w-3xl flex justify-center items-center">
        <a class="btn border border-white/40 absolute left-0 z-40" href={`/#projects`}>
          Volver
        </a>

        <h1 class="text-4xl font-bold text-white">{project.data.title}</h1>
      </div>

      <Carousel images={carouselImages} slug={project.id} />

      <div class="flex flex-col items-center max-w-3xl text-center gap-6">
        <div class="flex items-center gap-6">
          <p class="text-lg text-gray-300 max-w-2xl">
            {project.data.description}
            <br />
            Date: {project.data.date}
          </p>

          <a
            href={project.data.url}
            class="btn border border-white/40"
            target="_blank"
            rel="noopener noreferrer"
          >
            Visit Application
          </a>
        </div>
        
        <div class="prose text-left">
          <Content />
        </div>
      </div>
    </main>
  </div>
</Layout>
